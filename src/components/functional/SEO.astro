---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const SITE_URL = "https://joinrehuman.com";
const SITE_NAME = "re/Human";
const DEFAULT_DESCRIPTION =
  "In the age of AI, your only unfair advantage is your people. re/Human builds systems that scale authentic connection.";
const DEFAULT_OG_IMAGE = "/og-image.png";

const {
  title = SITE_NAME,
  description = DEFAULT_DESCRIPTION,
  canonical,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = "website",
  noindex = false,
  jsonLd,
} = Astro.props;

const pageTitle = title === SITE_NAME ? SITE_NAME : title;
const canonicalURL = canonical || new URL(Astro.url.pathname, SITE_URL).href;
const ogImageURL = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, SITE_URL).href;

const structuredData = jsonLd || {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "re/Human",
  url: SITE_URL,
  description: DEFAULT_DESCRIPTION,
  founder: {
    "@type": "Person",
    name: "Clark Sell",
  },
};
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}
<meta name="author" content="Clark Sell" />
<meta name="theme-color" content="#1A1A2E" />

<!-- Open Graph -->
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE_NAME} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@joinrehuman" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Structured Data -->
<script is:inline
  type="application/ld+json"
  set:html={JSON.stringify(structuredData)}
/>
