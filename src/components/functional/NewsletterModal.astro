---
/**
 * Newsletter modal that appears once when the user scrolls past a trigger point.
 * Dismissed via close button, backdrop click, or Escape key.
 * Won't reappear for 7 days after dismissal (localStorage).
 */
import NewsletterForm from "./NewsletterForm.astro";
---

<!-- Modal backdrop + container -->
<div
  id="newsletter-modal"
  class="fixed inset-0 z-50 flex items-center justify-center p-6 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div
    id="newsletter-modal-backdrop"
    class="absolute inset-0 bg-rh-ink/80 backdrop-blur-sm"
  >
  </div>

  <!-- Modal panel -->
  <div
    class="relative w-full max-w-2xl bg-rh-warm-dark border border-rh-chalk/10 p-8 md:p-10 transform scale-95 transition-transform duration-300"
    id="newsletter-modal-panel"
  >
    <!-- Close button -->
    <button
      id="newsletter-modal-close"
      class="absolute top-4 right-4 font-mono text-xs text-rh-chalk/40 hover:text-rh-ember transition-colors uppercase tracking-widest"
      aria-label="Close"
    >
      [ ESC ]
    </button>

    <!-- Header -->
    <div
      class="font-mono text-[10px] uppercase tracking-widest text-rh-ember/60 mb-6"
    >
      <span class="inline-block w-2 h-2 rounded-full bg-rh-ember animate-pulse mr-2"></span>
      SYS.INTERCEPT // SIGNAL_DETECTED
    </div>

    <h3
      class="font-heading text-3xl md:text-4xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mb-4"
    >
      Read the Manual.
    </h3>

    <p class="text-sm md:text-base text-rh-chalk/60 leading-relaxed mb-8">
      Weekly frameworks on community architecture and systems thinking for
      leaders building movements.
    </p>

    <NewsletterForm id="modal-newsletter" onSuccess="newsletter-modal-close" stacked />
  </div>
</div>

<script>
  const STORAGE_KEY = "rh_newsletter_dismissed";
  const DISMISS_DAYS = 7;
  const SCROLL_TRIGGER = 0.4; // 40% of page height

  const modal = document.getElementById("newsletter-modal");
  const panel = document.getElementById("newsletter-modal-panel");
  const backdrop = document.getElementById("newsletter-modal-backdrop");
  const closeBtn = document.getElementById("newsletter-modal-close");

  // Check if we should show the modal
  function shouldShow(): boolean {
    const dismissed = localStorage.getItem(STORAGE_KEY);
    if (!dismissed) return true;
    const dismissedAt = parseInt(dismissed, 10);
    const daysSince = (Date.now() - dismissedAt) / (1000 * 60 * 60 * 24);
    return daysSince > DISMISS_DAYS;
  }

  function openModal() {
    if (!modal) return;
    modal.classList.remove("opacity-0", "pointer-events-none");
    modal.classList.add("opacity-100", "pointer-events-auto");
    panel?.classList.remove("scale-95");
    panel?.classList.add("scale-100");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.remove("opacity-100", "pointer-events-auto");
    modal.classList.add("opacity-0", "pointer-events-none");
    panel?.classList.remove("scale-100");
    panel?.classList.add("scale-95");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    localStorage.setItem(STORAGE_KEY, Date.now().toString());
  }

  // Scroll trigger - fire once
  let triggered = false;

  function onScroll() {
    if (triggered) return;
    const scrollPercent =
      window.scrollY / (document.body.scrollHeight - window.innerHeight);
    if (scrollPercent >= SCROLL_TRIGGER) {
      triggered = true;
      openModal();
      window.removeEventListener("scroll", onScroll);
    }
  }

  if (shouldShow()) {
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  // Close handlers
  closeBtn?.addEventListener("click", closeModal);
  backdrop?.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  // Close on successful subscribe
  window.addEventListener("newsletter-modal-close", () => {
    setTimeout(closeModal, 2000); // let them see the success message
  });
</script>
