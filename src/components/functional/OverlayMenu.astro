---
import SectionLabel from "../../elements/SectionLabel.astro";
import NewsletterForm from "./NewsletterForm.astro";
---

<div
  id="overlay-menu"
  class="fixed inset-0 z-150 bg-rh-warm-dark opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
  <!-- Content wrapper -->
  <div
    id="overlay-menu-panel"
    class="h-full w-full overflow-y-auto transform scale-95 transition-transform duration-300"
  >
    <!-- Top bar -->
    <div
      class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-5 md:px-10"
    >
      <!-- Brand -->
      <a
        href="/"
        class="font-heading text-2xl font-black uppercase italic tracking-tight text-rh-chalk"
      >
        re/<span class="text-rh-ember">Human</span>
      </a>

      <!-- Close button -->
      <button
        id="overlay-menu-close"
        class="font-mono text-xs tracking-wider text-rh-chalk/60 hover:text-rh-ember transition-colors cursor-pointer"
        aria-label="Close menu"
      >
        [ CLOSE ]
      </button>
    </div>

    <!-- Main content -->
    <div
      class="mx-auto max-w-[1400px] px-6 md:px-10 pt-12 md:pt-20 pb-20"
    >
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

        <!-- Navigation -->
        <div class="lg:col-span-5">
          <SectionLabel
            text="SYS.NAV // DIRECTORY"
            dot
            class="text-rh-chalk/50! mb-8"
          />

          <nav class="space-y-5">
            <a
              href="https://blog.joinrehuman.com/"
              class="overlay-menu-link block font-heading text-4xl md:text-5xl lg:text-6xl font-black uppercase italic tracking-tight text-rh-chalk hover:text-rh-ember transition-colors duration-200"
            >
              Articles
            </a>
            <a
              href="/the-architect"
              class="overlay-menu-link block font-heading text-4xl md:text-5xl lg:text-6xl font-black uppercase italic tracking-tight text-rh-chalk hover:text-rh-ember transition-colors duration-200"
            >
              The Architect
            </a>
            <a
              href="mailto:hello@joinrehuman.com"
              class="overlay-menu-link block font-heading text-4xl md:text-5xl lg:text-6xl font-black uppercase italic tracking-tight text-rh-chalk hover:text-rh-ember transition-colors duration-200"
            >
              Contact
            </a>
          </nav>
        </div>

        <!-- Right column -->
        <div class="lg:col-span-7 flex flex-col gap-0">

          <!-- CTA Block -->
          <div class="border border-rh-chalk/10 p-6 md:p-8">
            <SectionLabel
              text="SYS.ACTION // DEPLOY"
              dot
              class="text-rh-chalk/50! mb-5"
            />
            <h3 class="font-heading text-xl md:text-2xl font-bold uppercase italic tracking-tight text-rh-chalk mb-3">
              Book an Architecture Review
            </h3>
            <p class="text-sm md:text-base text-rh-chalk/60 leading-relaxed mb-6 max-w-lg">
              A 60-minute strategy session where we diagnose your community system,
              identify the highest-leverage fixes, and map a scalable architecture
              — you'll leave with a concrete action plan.
            </p>
            <a
              href="/book"
              class="overlay-menu-link inline-flex items-center gap-3 bg-rh-ember px-8 py-4 font-mono text-sm font-bold uppercase tracking-wider text-white transition-transform duration-200 hover:scale-[1.03]"
            >
              BOOK_ARCHITECTURE_REVIEW
              <span class="text-white/70">→</span>
            </a>
          </div>

          <!-- Secondary sections -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
            <!-- About -->
            <div class="border border-rh-chalk/10 border-t-0 p-6 md:p-8">
              <SectionLabel
                text="> SYS.ABOUT // SIGNAL"
                class="text-rh-chalk/50! mb-4"
              />
              <p class="text-base text-rh-chalk/60 leading-relaxed">
                re/Human helps community-driven companies architect scalable systems
                that turn members into movements.
              </p>
            </div>

            <!-- Social links -->
            <div class="border border-rh-chalk/10 border-t-0 md:border-l-0 p-6 md:p-8">
              <SectionLabel
                text="> SYS.NET // CONNECT"
                class="text-rh-chalk/50! mb-4"
              />
              <div class="flex flex-wrap items-center gap-3">
                <a
                  href="https://www.linkedin.com/company/joinrehuman/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 border border-rh-chalk/15 px-4 py-2.5 hover:border-rh-ember hover:text-rh-ember transition-colors group"
                >
                  <svg class="w-4 h-4 text-rh-chalk/50 group-hover:text-rh-ember transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  <span class="font-mono text-xs uppercase tracking-widest text-rh-chalk/60 group-hover:text-rh-ember transition-colors">LinkedIn</span>
                </a>
                <a
                  href="https://x.com/joinrehuman"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 border border-rh-chalk/15 px-4 py-2.5 hover:border-rh-ember hover:text-rh-ember transition-colors group"
                >
                  <svg class="w-4 h-4 text-rh-chalk/50 group-hover:text-rh-ember transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                  <span class="font-mono text-xs uppercase tracking-widest text-rh-chalk/60 group-hover:text-rh-ember transition-colors">X / Twitter</span>
                </a>
                <a
                  href="https://www.youtube.com/@joinrehuman"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 border border-rh-chalk/15 px-4 py-2.5 hover:border-rh-ember hover:text-rh-ember transition-colors group"
                >
                  <svg class="w-4 h-4 text-rh-chalk/50 group-hover:text-rh-ember transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                  <span class="font-mono text-xs uppercase tracking-widest text-rh-chalk/60 group-hover:text-rh-ember transition-colors">YouTube</span>
                </a>
              </div>
            </div>
          </div>

          <!-- Newsletter -->
          <div class="border border-rh-chalk/10 border-t-0 p-6 md:p-8">
            <SectionLabel
              text="> SYS.ARCHIVE // SUBSCRIBE"
              class="text-rh-chalk/50! mb-4"
            />
            <p class="text-sm text-rh-chalk/50 mb-6">
              Weekly frameworks on community architecture and systems thinking.
            </p>
            <NewsletterForm id="overlay-newsletter" stacked />
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById("overlay-menu");
  const panel = document.getElementById("overlay-menu-panel");
  const closeBtn = document.getElementById("overlay-menu-close");
  const links = document.querySelectorAll(".overlay-menu-link");

  function openMenu() {
    if (!overlay) return;
    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100", "pointer-events-auto");
    panel?.classList.remove("scale-95");
    panel?.classList.add("scale-100");
    overlay.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    if (!overlay) return;
    overlay.classList.remove("opacity-100", "pointer-events-auto");
    overlay.classList.add("opacity-0", "pointer-events-none");
    panel?.classList.remove("scale-100");
    panel?.classList.add("scale-95");
    overlay.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    window.dispatchEvent(new CustomEvent("overlay-menu-closed"));
  }

  // Listen for toggle event from navbar
  window.addEventListener("overlay-menu-toggle", () => {
    const isOpen = overlay?.classList.contains("opacity-100");
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // Close button
  closeBtn?.addEventListener("click", closeMenu);

  // Escape key
  document.addEventListener("keydown", (e) => {
    if (
      e.key === "Escape" &&
      overlay?.classList.contains("opacity-100")
    ) {
      closeMenu();
    }
  });

  // Close on nav link click - animate out before navigating
  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      // Let external links and mailto open normally
      if (!href || href.startsWith("mailto:") || href.startsWith("http")) {
        closeMenu();
        return;
      }
      e.preventDefault();
      closeMenu();
      // Navigate after the 300ms transition completes
      setTimeout(() => {
        window.location.href = href;
      }, 300);
    });
  });
</script>
