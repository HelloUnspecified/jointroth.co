---
/**
 * Reusable newsletter signup form.
 * Posts to /api/subscribe (Beehiiv).
 * Each instance needs a unique `id` prop to avoid DOM collisions.
 */
interface Props {
  id?: string;
  class?: string;
  onSuccess?: string;
  stacked?: boolean;
}

const { id = "newsletter", class: className = "", onSuccess, stacked = false } = Astro.props;
---

<form id={`${id}-form`} class:list={["max-w-2xl", className]}>
  <div class:list={["flex flex-col gap-4", !stacked && "lg:flex-row"]}>
    <input
      type="email"
      name="email"
      id={`${id}-email`}
      required
      data-1p-ignore
      autocomplete="off"
      placeholder="[ awaiting_input: user@domain.com ]"
      class="text-sm bg-transparent border-b-2 border-rh-chalk/30 text-rh-chalk px-4 py-4 focus:outline-none focus:border-rh-ember transition-colors w-full font-mono placeholder:text-rh-chalk/30"
    />
    <button
      type="submit"
      class="font-mono text-sm uppercase tracking-widest text-rh-ember px-8 py-4 border border-transparent hover:border-rh-ember transition-colors shrink-0"
    >
      [ INITIATE_PROTOCOL ]
    </button>
  </div>
  <p id={`${id}-message`} class="mt-6"></p>
</form>

<script is:inline define:vars={{ id, onSuccess }}>
  const form = document.getElementById(`${id}-form`);
  const messageEl = document.getElementById(`${id}-message`);

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const emailInput = document.getElementById(`${id}-email`);
    const submitButton = form.querySelector('button[type="submit"]');
    const email = emailInput.value;

    emailInput.disabled = true;
    submitButton.disabled = true;
    const originalButtonText = submitButton.textContent;
    submitButton.textContent = "[ TRANSMITTING... ]";
    submitButton.classList.add("animate-pulse", "opacity-50");
    messageEl.textContent = "";

    try {
      const response = await fetch("/api/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      const data = await response.json();

      if (response.ok) {
        messageEl.textContent =
          "[ PROTOCOL_INITIATED ] Check your inbox to confirm your subscription.";
        messageEl.className = "mt-6 font-mono text-sm text-rh-ember";
        emailInput.value = "";

        if (onSuccess) {
          window.dispatchEvent(new CustomEvent(onSuccess));
        }
      } else {
        messageEl.textContent = `[ ERROR ] ${data.error || "Transmission failed. Try again."}`;
        messageEl.className = "mt-6 font-mono text-sm text-red-400";
      }
    } catch (error) {
      messageEl.textContent =
        "[ CONNECTION_LOST ] Network error. Please retry.";
      messageEl.className = "mt-6 font-mono text-sm text-red-400";
    } finally {
      emailInput.disabled = false;
      submitButton.disabled = false;
      submitButton.textContent = originalButtonText;
      submitButton.classList.remove("animate-pulse", "opacity-50");
    }
  });
</script>
