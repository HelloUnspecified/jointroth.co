---
import SectionLabel from "../../elements/SectionLabel.astro";
---

<section
  class="min-h-[60vh] flex flex-col items-center justify-center text-center px-6 pt-24 pb-16"
>
  <SectionLabel
    text="> SYS.CONFIRM // SESSION_BOOKED"
    class="text-rh-chalk/50!"
  />

  <h1
    class="font-heading text-5xl md:text-7xl lg:text-8xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mt-8"
  >
    YOU'RE <span class="text-rh-ember">IN.</span>
  </h1>

  <p
    class="text-lg md:text-xl text-rh-chalk/70 leading-relaxed max-w-2xl mt-8"
  >
    Your architecture session is locked. Complete the steps below so we can
    hit the ground running.
  </p>

  <div class="mt-12 animate-bounce">
    <span class="font-mono text-xs uppercase tracking-widest text-rh-ember">
      [ SCROLL TO PREPARE ]
    </span>
  </div>
</section>
