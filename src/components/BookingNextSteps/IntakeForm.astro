---
import SectionLabel from "../../elements/SectionLabel.astro";
---

<section class="py-32 px-6 md:px-10" id="intake">
  <div class="mx-auto max-w-[900px]">
    <SectionLabel
      text="> SYS.INPUT // INTAKE_FORM"
      class="text-rh-chalk/50! mb-8"
    />

    <h2
      class="font-heading text-3xl md:text-4xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mb-4"
    >
      Tell Us About<br />Your Ecosystem.
    </h2>

    <p class="text-lg text-rh-chalk/70 leading-relaxed mb-12">
      Complete this quick intake so we come prepared with insights specific to
      your community.
    </p>

    <!-- Fillout Form Embed -->
    <div class="rounded-2xl border border-rh-chalk/10 overflow-hidden">
      <script src="https://server.fillout.com/embed/v1/"></script>
      <div
        data-fillout-id="gctYQFDV2mus"
        data-fillout-embed-type="standard"
        data-fillout-inherit-parameters
        data-fillout-dynamic-resize
        style="width:100%;height:600px;"
      >
      </div>
    </div>
  </div>
</section>
