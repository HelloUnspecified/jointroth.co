---
// One "We're building a marriage where…" line, authored and dated.
interface Props {
  author?: string;
  date?: string;
  divider?: boolean;
  class?: string;
}
const { author, date, divider = true, class: className } = Astro.props;
const meta = [author, date].filter(Boolean).join(" · ");
---

<div
  class={className}
  style={`padding-bottom:24px;margin-bottom:24px;border-bottom:${divider ? "1px solid var(--color-border)" : "none"}`}
>
  <div
    style="font-family:var(--font-serif);font-size:24px;line-height:1.32;color:var(--color-text);letter-spacing:-0.004em"
  >
    <slot />
  </div>
  {
    meta && (
      <div style="font-family:var(--font-sans);font-size:13px;color:var(--color-text-tertiary);margin-top:14px">
        {meta}
      </div>
    )
  }
</div>
