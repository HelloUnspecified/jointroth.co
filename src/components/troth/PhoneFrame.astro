---
// The iPhone frame shell shared by every page: cream canvas, the device frame,
// the simulated iOS status bar (desktop-only), and the Lamplight toggle.
// Page content goes in the default slot. The theme-toggle behavior ships with
// the toggle button, so every page that uses PhoneFrame gets it.
---

<div
  style="min-height:100vh;background:var(--color-canvas);display:flex;justify-content:center;padding:clamp(0px,3.5vw,40px);transition:background var(--dur-considered) var(--ease-troth)"
>
  <div
    style="position:relative;width:100%;max-width:462px;background:var(--color-bg);border:1px solid var(--color-border);border-radius:clamp(0px,3vw,30px);overflow:clip;transition:background var(--dur-considered) var(--ease-troth)"
  >
    {
      /* iOS status bar — hidden on phones via .troth-phone (see troth-ui.css) */
    }
    <div
      class="troth-statusbar"
      aria-hidden="true"
      style="position:absolute;top:0;left:0;right:0;z-index:58;width:100%;height:46px;display:flex;align-items:center;justify-content:space-between;padding:0 26px;border-top-left-radius:clamp(0px,3vw,30px);border-top-right-radius:clamp(0px,3vw,30px)"
    >
      <span
        style="font-family:var(--font-sans);font-size:14px;font-weight:600;letter-spacing:0.01em;color:var(--color-text)"
        >9:41</span
      >
      <div
        style="position:absolute;top:9px;left:50%;transform:translateX(-50%);width:110px;height:26px;background:#17120E;border-radius:999px"
      >
      </div>
      <div
        style="display:flex;align-items:center;gap:7px;color:var(--color-text)"
      >
        <svg width="18" height="12" viewBox="0 0 18 12" fill="currentColor">
          <rect x="0" y="8" width="3" height="4" rx="0.8"></rect>
          <rect x="5" y="5.5" width="3" height="6.5" rx="0.8"></rect>
          <rect x="10" y="3" width="3" height="9" rx="0.8"></rect>
          <rect x="15" y="0.5" width="3" height="11.5" rx="0.8"></rect>
        </svg>
        <svg
          width="17"
          height="12"
          viewBox="0 0 17 12"
          fill="none"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
        >
          <path d="M1 4.2C3.1 2.2 5.7 1 8.5 1s5.4 1.2 7.5 3.2"></path>
          <path d="M3.4 6.9c1.4-1.3 3.2-2 5.1-2s3.7.7 5.1 2"></path>
          <path d="M6 9.4c.7-.7 1.6-1 2.5-1s1.8.3 2.5 1"></path>
          <circle cx="8.5" cy="11.1" r="0.7" fill="currentColor" stroke="none"
          ></circle>
        </svg>
        <svg width="26" height="13" viewBox="0 0 26 13" fill="none">
          <rect
            x="0.6"
            y="0.6"
            width="21"
            height="11.8"
            rx="3"
            stroke="currentColor"
            stroke-opacity="0.5"
            stroke-width="1.1"></rect>
          <rect
            x="2.2"
            y="2.2"
            width="16"
            height="8.6"
            rx="1.6"
            fill="currentColor"></rect>
          <rect
            x="23"
            y="4"
            width="1.8"
            height="5"
            rx="0.9"
            fill="currentColor"
            fill-opacity="0.5"></rect>
        </svg>
      </div>
    </div>

    {/* Lamplight toggle */}
    <button
      type="button"
      data-lamplight-toggle
      aria-label="Toggle lamplight"
      style="position:fixed;top:calc(clamp(0px,3.5vw,40px) + 54px);right:calc(clamp(0px,3.5vw,40px) + 14px);z-index:55;display:inline-flex;align-items:center;gap:7px;font-family:var(--font-sans);font-size:11px;font-weight:600;letter-spacing:0.04em;color:var(--color-text-secondary);background:color-mix(in srgb, var(--color-bg) 70%, transparent);backdrop-filter:blur(10px);border:1px solid var(--color-border);border-radius:999px;padding:6px 12px 6px 10px;cursor:pointer"
    >
      <svg
        width="16"
        height="11"
        viewBox="0 0 64 40"
        fill="none"
        style="display:block"
      >
        <path
          d="M18.5 6.2c4.1 0 7 6.4 7 14.1 0 7.7-2.9 13.9-7 13.9s-7-6.2-7-13.9c0-7.7 2.9-14.1 7-14.1Z"
          fill="currentColor"
          opacity="0.55"></path>
        <path
          d="M39.5 6.2c4.1 0 7 6.4 7 14.1 0 7.7-2.9 13.9-7 13.9s-7-6.2-7-13.9c0-7.7 2.9-14.1 7-14.1Z"
          fill="currentColor"></path>
      </svg>
      <span data-lamplight-label>Lamplight</span>
    </button>

    <slot />
  </div>
</div>

<script>
  const btn = document.querySelector<HTMLButtonElement>(
    "[data-lamplight-toggle]",
  );
  if (btn) {
    const label = btn.querySelector<HTMLElement>("[data-lamplight-label]");
    const root = document.documentElement;
    const sync = () => {
      if (label)
        label.textContent = root.classList.contains("troth-dark")
          ? "Light"
          : "Lamplight";
    };
    sync();
    btn.addEventListener("click", () => {
      const dark = root.classList.toggle("troth-dark");
      if (dark) root.setAttribute("data-theme", "dark");
      else root.removeAttribute("data-theme");
      try {
        localStorage.setItem("troth-theme", dark ? "dark" : "light");
      } catch (e) {}
      sync();
    });
  }
</script>
