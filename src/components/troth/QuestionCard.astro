---
// The occasionally-surfaced connection question.
import Eyebrow from "../../elements/Eyebrow.astro";
import Button from "../../elements/Button.astro";
interface Props {
  question: string;
  primaryLabel?: string;
  secondaryLabel?: string;
  class?: string;
}
const {
  question,
  primaryLabel = "Answer together",
  secondaryLabel,
  class: className,
} = Astro.props;
---

<div
  class={className}
  style="background:var(--color-surface-sunken);border:1px solid var(--color-border);border-radius:var(--radius-card);padding:20px 22px"
>
  <Eyebrow tone="letter" style="margin-bottom:12px"
    >A question, if you'd like one</Eyebrow
  >
  <div
    style="font-family:var(--font-serif);font-size:24px;line-height:1.3;color:var(--color-text);margin-bottom:18px"
  >
    {question}
  </div>
  <div style="display:flex;gap:12px">
    <Button>{primaryLabel}</Button>
    {secondaryLabel && <Button variant="secondary">{secondaryLabel}</Button>}
  </div>
</div>
