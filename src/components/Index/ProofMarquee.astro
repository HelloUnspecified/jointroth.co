---
import { getEntry } from "astro:content";

const entry = await getEntry("index", "proofmarquee");
const { people } = entry?.data;
const allCards = [...people, ...people, ...people];

import SectionLabel from "../../elements/SectionLabel.astro";
import Heading from "../../elements/Heading.astro";
---

<section
  class="bg-rh-warm-light dark:bg-rh-warm-dark flex flex-col justify-center py-28 md:py-40 px-6 md:px-10 overflow-hidden"
>
  <div class="mx-auto max-w-[1400px] w-full">
    <!-- System Header -->
    <div class="mb-12">
      <SectionLabel text="> SYS.PROOF // THE_HUMANS" />
    </div>

    <!-- Massive Text -->
    <Heading size="xl" class="mb-12 tracking-tight">
      High-Tech<br />Humanist
    </Heading>
  </div>

  <!-- Infinite Marquee Wrapper -->
  <div class="relative w-full overflow-hidden pt-6 pb-8" id="marquee-wrapper">
    <!-- Left Edge Fade -->
    <div
      class="absolute left-0 top-0 bottom-0 w-24 md:w-40 z-10 bg-linear-to-r from-rh-warm-light dark:from-rh-warm-dark to-transparent pointer-events-none"
    >
    </div>
    <!-- Right Edge Fade -->
    <div
      class="absolute right-0 top-0 bottom-0 w-24 md:w-40 z-10 bg-linear-to-l from-rh-warm-light dark:from-rh-warm-dark to-transparent pointer-events-none"
    >
    </div>

    <!-- Scrolling Track -->
    <div
      id="marquee-track"
      class="flex items-stretch gap-8 w-max"
      style="animation: marquee-scroll 30s linear infinite;"
    >
      {
        allCards.map((person) => (
          <a
            href="#"
            class="group flex flex-col w-[320px] shrink-0 bg-rh-warm-light dark:bg-rh-warm-dark p-6 rounded-4xl shadow-xl ring-1 ring-rh-ink/5 dark:ring-rh-chalk/5 transition-all duration-500 hover:scale-105 hover:-translate-y-3 cursor-pointer"
          >
            {/* Portrait */}
            <div class="relative w-full h-[200px] mb-6 shrink-0 overflow-hidden rounded-2xl">
              <img
                src={person.img.replace(/\.(jpg|jpeg|png)$/, ".webp")}
                alt={person.name}
                width="640"
                height="400"
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover grayscale contrast-125 group-hover:grayscale-0 transition-all duration-700"
              />
            </div>
            {/* Name */}
            <h4 class="font-heading font-bold text-xl uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-4">
              {person.name}
            </h4>
            {/* Transformation */}
            <p
              class="text-sm text-rh-ink/70 dark:text-rh-chalk/70 leading-relaxed"
              set:html={person.transformation}
            />
            {/* Logo & CTA Footer */}
            <div class="mt-auto pt-6 border-t border-black/10 dark:border-white/10 flex items-center justify-between">
              <span class="font-mono text-xs uppercase tracking-widest text-rh-ink/50 dark:text-rh-chalk/50 group-hover:text-rh-ember transition-colors duration-300">
                {person.company}
              </span>
              <span class="font-mono text-rh-ember text-xs uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all transform -translate-x-2.5 group-hover:translate-x-0 duration-300">
                View ↗
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<script>
  const wrapper = document.getElementById("marquee-wrapper");
  const track = document.getElementById("marquee-track");
  if (wrapper && track) {
    wrapper.addEventListener("mouseenter", () => {
      track.style.animationPlayState = "paused";
    });
    wrapper.addEventListener("mouseleave", () => {
      track.style.animationPlayState = "running";
    });
  }
</script>
