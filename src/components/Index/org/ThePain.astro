---
import SectionLabel from "../../../elements/SectionLabel.astro";
import Heading from "../../../elements/Heading.astro";
---

<section
  class="bg-rh-warm-light dark:bg-rh-warm-dark py-32 md:py-48 px-6 md:px-10"
  id="the-pain-section"
>
  <div class="mx-auto w-full max-w-[1400px]">
    <!-- Terminal Header -->
    <div class="pain-reveal mb-10">
      <SectionLabel text="> SYS.DIAGNOSTIC // STATUS_CRITICAL" />
    </div>

    <!-- Headline -->
    <Heading class="pain-reveal mb-16 max-w-4xl">
      The symptoms are <span class="text-rh-ember">everywhere.</span>
    </Heading>

    <!-- Symptom List - staggered terminal-style lines -->
    <div class="max-w-3xl space-y-4 mb-16">
      <p
        class="pain-line font-mono text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
      >
        <span class="text-rh-ember/70 mr-2">▸</span> Your community is quiet.
      </p>
      <p
        class="pain-line font-mono text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
      >
        <span class="text-rh-ember/70 mr-2">▸</span> Your people leave.
      </p>
      <p
        class="pain-line font-mono text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
      >
        <span class="text-rh-ember/70 mr-2">▸</span> Your audience doesn't
        convert to loyalty.
      </p>
      <p
        class="pain-line font-mono text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
      >
        <span class="text-rh-ember/70 mr-2">▸</span> Your culture breaks the
        moment you step out of the room.
      </p>
    </div>

    <!-- The failed attempts -->
    <div class="pain-reveal max-w-3xl">
      <p
        class="text-lg md:text-xl text-rh-ink/50 dark:text-rh-chalk/50 leading-relaxed mb-6"
      >
        You've rebranded. Switched platforms. Hired agencies. Reorganized the
        team. Posted more content.
      </p>
      <p
        class="text-xl md:text-2xl font-heading font-black uppercase italic text-rh-ink dark:text-rh-chalk leading-tight"
      >
        None of it held. Because none of it was the disease.
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Reveal header + headline
  gsap.fromTo(
    ".pain-reveal",
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.3,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#the-pain-section",
        start: "top 70%",
      },
    },
  );

  // Staggered symptom lines - typewriter-style reveal
  gsap.fromTo(
    ".pain-line",
    { opacity: 0, x: -20 },
    {
      opacity: 1,
      x: 0,
      duration: 0.6,
      stagger: 0.15,
      ease: "power2.out",
      scrollTrigger: {
        trigger: "#the-pain-section",
        start: "top 60%",
      },
    },
  );
</script>
