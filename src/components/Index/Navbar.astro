---

---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-100 transition-all duration-300"
>
  <div
    class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-5 md:px-10"
  >
    <!-- Brand -->
    <a
      href="/"
      class="font-heading text-2xl font-black uppercase italic tracking-tight text-rh-ink dark:text-rh-chalk"
    >
      re/<span class="text-rh-ember">Human</span>
    </a>

    <!-- Right Side -->
    <div class="flex items-center gap-4">
      <!-- Theme Toggle (hidden on mobile to avoid collision) -->
      <button
        id="theme-toggle"
        class="hidden md:inline-flex font-mono text-xs tracking-wider text-rh-ink/60 dark:text-rh-chalk/60 hover:text-rh-ember transition-colors cursor-pointer"
        aria-label="Toggle theme"
      >
        [<span id="toggle-label"
          >LGT / <span class="text-rh-ember font-bold">DRK</span></span
        >]
      </button>

      <!-- Menu Toggle -->
      <button
        id="menu-toggle"
        class="font-mono text-xs tracking-wider text-rh-ink/60 dark:text-rh-chalk/60 hover:text-rh-ember transition-colors cursor-pointer"
        aria-label="Open menu"
      >
        [<span id="menu-toggle-label">MENU</span>]
      </button>

      <!-- CTA -->
      <a
        href="/book"
        class="group relative hidden md:inline-flex items-center gap-2 bg-rh-ember px-5 py-2.5 font-mono text-xs font-bold uppercase tracking-wider text-white transition-transform duration-200 hover:scale-[1.03]"
      >
        BOOK_ARCHITECTURE_REVIEW
      </a>
    </div>
  </div>
</nav>

<script>
  // Theme toggle logic
  const toggle = document.getElementById("theme-toggle");
  const label = document.getElementById("toggle-label");

  function updateLabel() {
    const isDark = document.documentElement.classList.contains("dark");
    if (label) {
      if (isDark) {
        label.innerHTML = `<span class="text-rh-ember font-bold">LGT</span> / DRK`;
      } else {
        label.innerHTML = `LGT / <span class="text-rh-ember font-bold">DRK</span>`;
      }
    }
  }

  updateLabel();

  toggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("rh-theme", isDark ? "dark" : "light");
    updateLabel();
  });

  // Menu toggle
  const menuToggle = document.getElementById("menu-toggle");
  const menuLabel = document.getElementById("menu-toggle-label");
  let menuOpen = false;

  menuToggle?.addEventListener("click", () => {
    menuOpen = !menuOpen;
    if (menuLabel) {
      menuLabel.textContent = menuOpen ? "CLOSE" : "MENU";
    }
    window.dispatchEvent(new CustomEvent("overlay-menu-toggle"));
  });

  window.addEventListener("overlay-menu-closed", () => {
    menuOpen = false;
    if (menuLabel) {
      menuLabel.textContent = "MENU";
    }
  });

  // Navbar backdrop blur on scroll
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      navbar?.classList.add(
        "backdrop-blur-xl",
        "bg-rh-warm-light/80",
        "dark:bg-rh-warm-dark/80",
      );
    } else {
      navbar?.classList.remove(
        "backdrop-blur-xl",
        "bg-rh-warm-light/80",
        "dark:bg-rh-warm-dark/80",
      );
    }
  });
</script>
