---
import SectionLabel from "../../elements/SectionLabel.astro";
import Heading from "../../elements/Heading.astro";
---

<section
  id="website"
  class="relative flex min-h-dvh items-center overflow-hidden bg-rh-warm-light dark:bg-rh-warm-dark"
>
  <!-- Background Code Stream (canvas-rendered, no DOM text pollution) -->
  <div
    class="pointer-events-none absolute inset-0 overflow-hidden"
    aria-hidden="true"
  >
    <div class="relative w-[75%] h-full">
      <canvas
        id="hero-code-stream"
        class="absolute inset-0 w-full h-full select-none"></canvas>
      <!-- Right fade so text dissolves at the edge -->
      <div
        class="absolute top-0 right-0 bottom-0 w-32 md:w-48 hero-grid-fade-r"
      >
      </div>
    </div>
  </div>
  <!-- Bottom fade gradient -->
  <div
    class="pointer-events-none absolute bottom-0 left-0 right-0 h-48 hero-bottom-fade"
  >
  </div>

  <div
    class="relative z-10 mx-auto w-full max-w-[1400px] px-6 md:px-10 pt-32 pb-20"
  >
    <!-- System Header -->
    <div class="hero-fade mb-8">
      <SectionLabel text="SYS.CORE // ONLINE" dot />
    </div>

    <!-- Headline -->
    <Heading as="h1" size="lg" class="hero-fade mb-12 max-w-5xl tracking-tight">
      <div class="leading-[.9]">Humans are the real infrastructure.</div>

      <div class="pt-10 leading-[.9]">Most organizations haven't built it.</div>
    </Heading>

    <!-- Manifesto lines -->
    <div class="hero-fade max-w-2xl mb-12 space-y-2">
      <p
        class="font-mono text-sm md:text-base text-rh-ink/50 dark:text-rh-chalk/50 leading-relaxed"
      >
        Your teams are shrinking. Your culture doesn't scale.
      </p>
      <p
        class="font-mono text-sm md:text-base text-rh-ink/50 dark:text-rh-chalk/50 leading-relaxed"
      >
        AI is replacing the tasks. Nobody is replacing the connections.
      </p>
      <p
        class="font-mono text-sm md:text-base text-rh-ink/50 dark:text-rh-chalk/50 leading-relaxed"
      >
        The human layer was never designed. Now it's breaking.
      </p>
    </div>

    <!-- Subheadline -->
    <!-- <BodyText class="hero-fade max-w-2xl mb-12">
      re/Human architects the human infrastructure for what comes next.
    </BodyText> -->

    <!-- Founder CTA - identity + action as one unit -->
    <div
      class="hero-fade mb-16 md:mb-24 w-full md:w-fit founder-cta-wrapper relative p-px"
    >
      <a
        href="/book"
        class="group relative flex flex-col md:grid md:grid-cols-[auto_1fr] gap-4 md:gap-x-6 md:gap-y-3 md:items-center bg-rh-warm-light dark:bg-rh-warm-dark p-5 md:p-6"
      >
        <img
          src="/assets/img/pictures/clark-stage-01.webp"
          alt="Clark Sell"
          width="400"
          height="400"
          fetchpriority="high"
          class="md:row-span-2 w-16 h-16 md:w-26 md:h-26 rounded-full object-cover border-2 border-rh-ember/30"
        />
        <div class="text-left">
          <div
            class="font-mono text-xs md:text-sm uppercase tracking-widest text-rh-ink/50 dark:text-rh-chalk/50 leading-relaxed"
          >
            re/Human architects the human infrastructure for what comes next.
          </div>
          <div
            class="font-mono text-[9px] md:text-sm uppercase tracking-widest text-rh-ink/30 dark:text-rh-chalk/30 mt-1"
          >
            <span id="founder-terminal-line"></span><span
              id="founder-cursor"
              class="inline-block w-0.5 h-[1em] bg-rh-ember ml-1 align-middle opacity-0"
            ></span>
          </div>
        </div>
        <span
          class="font-mono text-xs md:text-base uppercase tracking-widest text-rh-ember group-hover:translate-x-1 transition-transform duration-300 md:justify-self-end md:text-right"
          >SCHEDULE AN ARCHITECTURE REVIEW →
        </span>
      </a>
    </div>

    <!-- Scroll Indicator
    <div class="hero-fade">
      <div
        class="flex items-center gap-3 font-mono text-xs text-rh-ink/30 dark:text-rh-chalk/30 uppercase tracking-widest"
      >
        <span class="block h-8 w-px bg-rh-ember/50"></span>
        Scroll to explore
        <span class="inline-block w-2.5 h-4 md:h-5 bg-rh-ember animate-pulse"
        ></span>
      </div>
    </div> -->
  </div>
</section>

<style>
  .founder-cta-wrapper {
    background: rgba(0, 0, 0, 0.06);
  }

  :global(.dark) .founder-cta-wrapper {
    background: rgba(255, 255, 255, 0.06);
  }

  .founder-cta-wrapper::before {
    content: "";
    position: absolute;
    inset: 0;
    background: conic-gradient(
      from var(--border-angle, 0deg),
      transparent 0%,
      transparent 25%,
      #ff5733 50%,
      transparent 75%,
      transparent 100%
    );
    animation: rotate-border 4s linear infinite;
    opacity: 0.5;
  }

  .founder-cta-wrapper:hover::before {
    animation-play-state: paused;
    background: #ff5733;
    opacity: 1;
  }

  .founder-cta-wrapper > a {
    position: relative;
    z-index: 1;
  }

  @keyframes rotate-border {
    to {
      --border-angle: 360deg;
    }
  }

  @property --border-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .hero-grid-fade-r {
    background: linear-gradient(to right, transparent, #f9f8f6);
  }

  :global(.dark) .hero-grid-fade-r {
    background: linear-gradient(to right, transparent, #1a1918);
  }

  .hero-bottom-fade {
    background: linear-gradient(to bottom, transparent, #f9f8f6);
  }

  :global(.dark) .hero-bottom-fade {
    background: linear-gradient(to bottom, transparent, #1a1918);
  }
</style>

<script>
  import { gsap } from "gsap";

  // GSAP staggered fade-up
  gsap.fromTo(
    ".hero-fade",
    { opacity: 0, y: 40 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: "power3.out",
      delay: 0.3,
    },
  );

  // Background code stream via canvas (no DOM text)
  const codeCanvas = document.getElementById(
    "hero-code-stream",
  ) as HTMLCanvasElement | null;
  if (codeCanvas) {
    const ctx = codeCanvas.getContext("2d");
    if (ctx) {
      const tokens = [
        "HUMAN_PROTOCOL",
        "ARCH.REVIEW",
        "CONNECT.AUTH",
        "INFRA.HUMAN",
        "SOUL.RENDER",
        "CULTURE.SYNC",
        "TRUST_LAYER",
        "RETENTION.BIND",
        "SIGNAL.BOOST",
        "EMPATHY_ENGINE",
        "SCALE.HUMAN",
        "SYS.REDESIGN",
      ];
      const seededRandom = (seed: number) => {
        const x = Math.sin(seed) * 10000;
        return x - Math.floor(x);
      };

      const draw = () => {
        const dpr = window.devicePixelRatio || 1;
        const rect = codeCanvas.getBoundingClientRect();
        codeCanvas.width = rect.width * dpr;
        codeCanvas.height = rect.height * dpr;
        ctx.scale(dpr, dpr);

        const fontSize = 10;
        const lineHeight = fontSize * 1.8;
        ctx.font = `${fontSize}px "JetBrains Mono", ui-monospace, monospace`;

        const isDark = document.documentElement.classList.contains("dark");
        ctx.fillStyle = isDark
          ? "rgba(235, 233, 228, 0.06)"
          : "rgba(18, 18, 18, 0.04)";

        const rows = Math.ceil(rect.height / lineHeight) + 1;
        for (let i = 0; i < rows; i++) {
          let x = 0;
          const y = i * lineHeight + fontSize;
          for (let j = 0; j < 20; j++) {
            const token =
              tokens[
                Math.floor(seededRandom(i * 8 + j + 42) * tokens.length)
              ];
            ctx.fillText(token, x, y);
            x += ctx.measureText(token + "  ").width;
          }
        }
      };

      draw();
      window.addEventListener("resize", draw);
    }
  }

  // Terminal typewriter for founder identity line
  const termLine = document.getElementById("founder-terminal-line");
  const termCursor = document.getElementById("founder-cursor");
  if (termLine && termCursor) {
    const fullText = "> ID_VERIFIED // CLARK_SELL // HUMAN_ARCHITECT";
    const emberPrefix = "> ID_VERIFIED";
    let i = 0;

    // Show blinking cursor after the hero fades in
    setTimeout(() => {
      termCursor.style.opacity = "1";
      termCursor.style.animation = "cursor-blink 0.6s step-end infinite";

      const type = () => {
        if (i < fullText.length) {
          // Build the innerHTML with ember-colored prefix
          const current = fullText.slice(0, i + 1);
          if (i < emberPrefix.length) {
            termLine.innerHTML = `<span class="text-rh-ember">${current}</span>`;
          } else {
            termLine.innerHTML = `<span class="text-rh-ember">${emberPrefix}</span>${current.slice(emberPrefix.length)}`;
          }
          i++;
          // Vary speed slightly for realism
          const delay = current.endsWith("/") ? 80 : 40 + Math.random() * 30;
          setTimeout(type, delay);
        } else {
          // Stop cursor blink after typing finishes
          setTimeout(() => {
            termCursor.style.animation = "none";
            termCursor.style.opacity = "1";
          }, 1500);
        }
      };
      type();
    }, 1800); // wait for hero fade-in to finish
  }
</script>
