---
import SectionLabel from "../../elements/SectionLabel.astro";
import Heading from "../../elements/Heading.astro";
import BodyText from "../../elements/BodyText.astro";
import CTAButton from "../../elements/CTAButton.astro";
---

<section
  class="bg-rh-warm-light dark:bg-rh-warm-dark py-28 md:py-40 px-6 md:px-10"
  id="deliverables-section"
>
  <span id="service" class="sr-only"></span>
  <div class="mx-auto w-full max-w-[1400px]">
    <!-- Terminal Header -->
    <div class="deliverables-reveal mb-10">
      <SectionLabel text="> SYS.ENGAGE // PARTNERSHIP_MODEL" />
    </div>

    <!-- Headline -->
    <Heading class="deliverables-reveal mb-8 max-w-5xl tracking-tight">
      We architect it <span class="text-rh-ember">with you.</span>
    </Heading>

    <!-- Intro narrative -->
    <div class="deliverables-reveal max-w-3xl mb-20">
      <BodyText class="mb-6">
        Every organization is different. Some have teams but no strategy. Others
        have vision but no infrastructure. We meet you where you are and design
        the human architecture your organization needs to thrive in the AI era.
      </BodyText>
      <p class="font-mono text-sm md:text-base text-rh-ink/40 dark:text-rh-chalk/40 leading-relaxed">
        Not a marketing agency. Not community management. Not personal branding.<br />
        This is infrastructure design for human connection.
      </p>
    </div>

    <!-- Transformation outcomes: 2x2 grid -->
    <div class="mb-20">
      <p class="deliverables-reveal font-mono text-xs md:text-sm uppercase tracking-widest text-rh-ember mb-10">
        What changes when human architecture is in place
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12 max-w-5xl">
        <!-- Outcome 1 -->
        <div class="deliverables-outcome">
          <div class="flex items-start gap-4">
            <span class="font-mono text-rh-ember text-sm mt-1 shrink-0">01</span>
            <div>
              <h3 class="font-heading font-black uppercase italic text-lg md:text-xl text-rh-ink dark:text-rh-chalk leading-tight mb-3">
                Your community connects to each other
              </h3>
              <p class="text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed">
                Members stop consuming and start belonging. They build
                relationships with each other, not just with you. That's the
                shift from audience to community.
              </p>
            </div>
          </div>
        </div>

        <!-- Outcome 2 -->
        <div class="deliverables-outcome">
          <div class="flex items-start gap-4">
            <span class="font-mono text-rh-ember text-sm mt-1 shrink-0">02</span>
            <div>
              <h3 class="font-heading font-black uppercase italic text-lg md:text-xl text-rh-ink dark:text-rh-chalk leading-tight mb-3">
                Your culture scales without breaking
              </h3>
              <p class="text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed">
                What made your organization special at 20 people still works at
                2,000. Because it's designed into the infrastructure, not held
                together by a few key people.
              </p>
            </div>
          </div>
        </div>

        <!-- Outcome 3 -->
        <div class="deliverables-outcome">
          <div class="flex items-start gap-4">
            <span class="font-mono text-rh-ember text-sm mt-1 shrink-0">03</span>
            <div>
              <h3 class="font-heading font-black uppercase italic text-lg md:text-xl text-rh-ink dark:text-rh-chalk leading-tight mb-3">
                Your customers stay, refer, and build with you
              </h3>
              <p class="text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed">
                Retention stops being a problem you throw discounts at. People
                stay because they're connected to something real. LTV goes up.
                Acquisition costs go down.
              </p>
            </div>
          </div>
        </div>

        <!-- Outcome 4 -->
        <div class="deliverables-outcome">
          <div class="flex items-start gap-4">
            <span class="font-mono text-rh-ember text-sm mt-1 shrink-0">04</span>
            <div>
              <h3 class="font-heading font-black uppercase italic text-lg md:text-xl text-rh-ink dark:text-rh-chalk leading-tight mb-3">
                You own it. It compounds.
              </h3>
              <p class="text-sm md:text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed">
                No retainer lock-in. No vendor dependency. We work alongside your
                team to build infrastructure you understand, operate, and keep
                forever. It gets more valuable over time, not less.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- The partnership frame -->
    <div class="deliverables-reveal border-t border-rh-ink/10 dark:border-rh-chalk/10 pt-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-end">
        <!-- Left: the closer -->
        <div>
          <p class="font-heading text-2xl md:text-4xl font-black uppercase italic text-rh-ink dark:text-rh-chalk leading-tight mb-6">
            Human connection is about to become your
            <span class="text-rh-ember">competitive advantage.</span>
          </p>
          <BodyText>
            Let's talk about where your organization is today, where it needs to
            go, and what the path looks like. No pitch deck. Just a real
            conversation about your infrastructure.
          </BodyText>
        </div>

        <!-- Right: CTA -->
        <div class="lg:text-right">
          <CTAButton href="/book">BOOK_ARCHITECTURE_REVIEW</CTAButton>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    ".deliverables-reveal",
    { opacity: 0, y: 50 },
    {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.3,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#deliverables-section",
        start: "top 70%",
      },
    },
  );

  gsap.fromTo(
    ".deliverables-outcome",
    { opacity: 0, y: 30 },
    {
      opacity: 1,
      y: 0,
      duration: 0.7,
      stagger: 0.15,
      ease: "power2.out",
      scrollTrigger: {
        trigger: "#deliverables-section",
        start: "top 55%",
      },
    },
  );
</script>
