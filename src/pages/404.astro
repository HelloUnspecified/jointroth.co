---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page not found — Troth"
  description="This page could not be found."
  noindex
>
  <main
    style="min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px 30px;background:var(--color-bg)"
  >
    <svg
      width="54"
      height="34"
      viewBox="0 0 64 40"
      fill="none"
      role="img"
      aria-label="Troth"
      style="margin-bottom:28px"
    >
      <path
        d="M18.5 6.2c4.1 0 7 6.4 7 14.1 0 7.7-2.9 13.9-7 13.9s-7-6.2-7-13.9c0-7.7 2.9-14.1 7-14.1Z"
        fill="#A24B34"></path>
      <path
        d="M39.5 6.2c4.1 0 7 6.4 7 14.1 0 7.7-2.9 13.9-7 13.9s-7-6.2-7-13.9c0-7.7 2.9-14.1 7-14.1Z"
        fill="#7A2E39"></path>
    </svg>
    <div
      style="font-family:var(--font-sans);font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--color-accent)"
    >
      Nothing kept here
    </div>
    <h1
      style="font-family:var(--font-serif);font-weight:400;font-size:clamp(30px,8vw,42px);line-height:1.08;letter-spacing:-0.01em;color:var(--color-text);margin:14px 0 0"
    >
      This page went looking for a room that isn't here.
    </h1>
    <p
      style="font-family:var(--font-serif);font-size:17px;line-height:1.6;color:var(--color-text-secondary);margin:18px auto 0;max-width:26rem;text-wrap:pretty"
    >
      The page you're after may have moved, or never existed. Let's get you back
      to where the two of you started.
    </p>
    <a
      href="/"
      style="display:inline-flex;align-items:center;justify-content:center;margin-top:28px;font-family:var(--font-sans);font-size:15px;font-weight:500;padding:13px 22px;border-radius:var(--radius-input);background:var(--color-accent);color:var(--color-text-on-accent)"
      >Back to Troth</a
    >
  </main>
</Layout>
