---
import { getEntry } from "astro:content";
import SqueezeLayout from "../layouts/SqueezeLayout.astro";
import SectionLabel from "../elements/SectionLabel.astro";

const page = await getEntry("pages", "book");
const { title, description, ogType } = page?.data;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://joinrehuman.com/book#webpage",
      name: "Book Your Architecture Review",
      description:
        "Book a private architecture session with re/Human. Zero obligation strategy review for your community ecosystem.",
      url: "https://joinrehuman.com/book",
      isPartOf: {
        "@type": "WebSite",
        "@id": "https://joinrehuman.com/#website",
        name: "re/Human",
        url: "https://joinrehuman.com",
      },
    },
  ],
};
---

<SqueezeLayout
  title={title}
  description={description}
  ogType={ogType}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <script is:inline>
      window.SavvyCal =
        window.SavvyCal ||
        function () {
          (SavvyCal.q = SavvyCal.q || []).push(arguments);
        };
    </script>
    <script is:inline src="https://embed.savvycal.com/v1/embed.js"></script>
    <script is:inline>
      SavvyCal("init", { origin: "https://cal.joinrehuman.com" });
    </script>
  </Fragment>

  <!-- Minimal Header -->
  <nav
    id="book-navbar"
    class="fixed top-0 left-0 right-0 z-100 transition-all duration-300"
  >
    <div
      class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-5 md:px-10"
    >
      <a
        href="/"
        class="font-heading text-2xl font-black uppercase italic tracking-tight text-rh-chalk"
      >
        re/<span class="text-rh-ember">Human</span>
      </a>
      <SectionLabel
        text="SYS.SECURE // PRIVATE_SESSION"
        dot
        class="text-rh-chalk/50!"
      />
    </div>
  </nav>

  <script>
    const navbar = document.getElementById("book-navbar");
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        navbar?.classList.add("backdrop-blur-xl", "bg-rh-ink/80");
      } else {
        navbar?.classList.remove("backdrop-blur-xl", "bg-rh-ink/80");
      }
    });
  </script>

  <!-- Hook Section -->
  <section
    class="min-h-screen flex flex-col items-center justify-center text-center px-6 pt-24"
  >
    <!-- Terminal Header -->
    <SectionLabel
      text="> SYS.INITIATE // ARCHITECTURE_SESSION"
      class="text-rh-chalk/50!"
    />

    <!-- Headline -->
    <h1
      class="font-heading text-6xl md:text-8xl lg:text-9xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mt-8"
    >
      YOUR PEOPLE ARE <br />
      <span class="text-rh-ember">WAITING.</span>
    </h1>

    <!-- Sub-copy -->
    <p
      class="text-lg md:text-xl text-rh-chalk/70 leading-relaxed max-w-2xl mt-8"
    >
      Watch the breakdown. Then book your private strategy session with our
      team.
    </p>

    <!-- Scroll Indicator -->
    <div class="mt-16 animate-bounce">
      <span class="font-mono text-xs uppercase tracking-widest text-rh-ember"
        >[ SCROLL ]</span
      >
    </div>
  </section>

  <!-- VSL Video Section -->
  <section class="py-32 px-6 md:px-10">
    <div class="mx-auto max-w-[1000px]">
      <!-- Terminal Header -->
      <SectionLabel
        text="SYS.STREAM // VIDEO_BRIEF"
        dot
        class="text-rh-chalk/50! mb-8"
      />

      <!-- Video Container -->
      <div
        class="relative w-full aspect-video bg-rh-warm-dark rounded-2xl border border-rh-chalk/10 overflow-hidden"
      >
        <!-- Terminal Overlay Top Bar -->
        <div
          class="absolute top-0 left-0 right-0 z-10 flex items-center justify-between px-6 py-4 bg-linear-to-b from-rh-ink/80 to-transparent"
        >
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-rh-ember/60"></span>
            <span class="w-3 h-3 rounded-full bg-rh-chalk/20"></span>
            <span class="w-3 h-3 rounded-full bg-rh-chalk/20"></span>
          </div>
          <span
            class="font-mono text-xs uppercase tracking-widest text-rh-chalk/30"
          >
            rh_architecture_brief.mp4
          </span>
        </div>

        <!-- Video Placeholder -->
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <div
            class="w-20 h-20 rounded-full border-2 border-rh-ember flex items-center justify-center mb-6 hover:bg-rh-ember/10 transition-colors cursor-pointer"
          >
            <svg
              class="w-8 h-8 text-rh-ember ml-1"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M8 5v14l11-7z"></path>
            </svg>
          </div>
          <span
            class="font-mono text-xs uppercase tracking-widest text-rh-chalk/50"
          >
            [ CLICK TO PLAY ]
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Booking Section -->
  <section class="py-32 px-6 md:px-10" id="book">
    <div class="mx-auto max-w-[1400px]">
      <div class="flex flex-col md:flex-row gap-16 md:gap-24">
        <!-- Left: Firewall Copy -->
        <div class="flex-1 flex flex-col justify-center">
          <!-- Terminal Header -->
          <SectionLabel
            text="> SYS.FIREWALL // SESSION_BRIEF"
            class="text-rh-chalk/50! mb-8"
          />

          <h2
            class="font-heading text-5xl md:text-7xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-chalk mb-8"
          >
            This Isn't a<br />Sales Call.
          </h2>

          <p class="text-lg md:text-xl text-rh-chalk/70 leading-relaxed mb-8">
            It's a private architecture session. We'll map your current
            ecosystem, identify the structural gaps, and show you the exact
            blueprint to turn your audience into an unbreakable community.
          </p>

          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <span class="text-rh-ember font-mono text-sm mt-1">&gt;</span>
              <span class="text-lg text-rh-chalk/70"
                >Full ecosystem diagnostic</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-rh-ember font-mono text-sm mt-1">&gt;</span>
              <span class="text-lg text-rh-chalk/70"
                >Custom architecture blueprint</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-rh-ember font-mono text-sm mt-1">&gt;</span>
              <span class="text-lg text-rh-chalk/70"
                >Culture design framework</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-rh-ember font-mono text-sm mt-1">&gt;</span>
              <span class="text-lg text-rh-chalk/70"
                >Zero obligation. Zero pitch.</span
              >
            </li>
          </ul>

          <p class="font-mono text-xs uppercase tracking-widest text-rh-ember">
            [ LIMITED AVAILABILITY ]
          </p>
        </div>

        <!-- Right: Calendly Embed Placeholder -->
        <div
          class="bg-rh-warm-dark border border-white/10 rounded-2xl p-8 lg:p-12 min-h-[500px] flex flex-col relative overflow-hidden group shadow-2xl"
        >
          <div
            class="flex justify-between items-center border-b border-white/10 pb-4 mb-8"
          >
            <span
              class="font-mono text-xs text-rh-chalk/50 tracking-widest uppercase"
              >> SCHEDULING_PROTOCOL</span
            >
            <span
              class="flex items-center gap-2 font-mono text-xs text-green-400 uppercase tracking-widest"
            >
              <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"
              ></span>
              STATUS: READY
            </span>
          </div>

          <div
            id="terminal-log"
            class="font-mono text-sm text-rh-chalk/70 space-y-4 mb-auto grow"
          >
            <p class="terminal-line opacity-0" data-final-opacity="0.5">
              > [SYSTEM] Secure connection established.
            </p>
            <p class="terminal-line opacity-0" data-final-opacity="0.7">
              > [SYSTEM] Scanning availability matrix...
            </p>
            <p class="terminal-line opacity-0 text-green-400">
              > [OK] Calendar data synced.
            </p>
            <p class="terminal-line opacity-0 text-rh-ember">
              > [ACTION_REQUIRED] Awaiting user initialization.
            </p>
          </div>

          <a
            id="terminal-cta"
            href="https://cal.joinrehuman.com/free-strategy-review"
            data-savvycal-embed
            class="block w-full text-center bg-rh-chalk text-rh-ink hover:bg-rh-ember hover:text-white transition-colors duration-300 font-black uppercase text-xl md:text-2xl py-6 rounded-xl tracking-tight mt-12 shadow-xl opacity-0 translate-y-4"
          >
            BOOK SESSION
          </a>
          <p
            id="terminal-footer"
            class="font-mono text-[10px] text-center text-rh-chalk/30 mt-10 tracking-widest uppercase opacity-0"
          >
            [ ZERO OBLIGATION. ZERO PITCH. ]
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Micro Footer -->
  <footer class="py-12 px-6 border-t border-rh-chalk/10">
    <div
      class="mx-auto max-w-[1400px] flex flex-col md:flex-row justify-between items-center gap-6"
    >
      <span
        class="font-mono text-xs uppercase tracking-widest text-rh-chalk/50"
      >
        &copy; 2026 RE/HUMAN. ALL RIGHTS RESERVED.
      </span>
      <div
        class="font-mono text-xs uppercase tracking-widest text-rh-chalk/50 flex items-center"
      >
        <span
          class="inline-block w-2 h-2 rounded-full bg-rh-ember animate-pulse mr-2"
        ></span>
        <span class="text-rh-ember">HUMAN PROTOCOL // ACTIVE</span>
      </div>
    </div>
  </footer>

  <script>
    // Terminal log typewriter animation
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          const lines = document.querySelectorAll(".terminal-line");
          const cta = document.getElementById("terminal-cta");
          const footer = document.getElementById("terminal-footer");

          lines.forEach((line, i) => {
            setTimeout(() => {
              const el = line as HTMLElement;
              const finalOpacity = el.dataset.finalOpacity || "1";
              el.style.transition = "opacity 0.3s ease, transform 0.3s ease";
              el.style.opacity = finalOpacity;
              el.style.transform = "translateY(0)";
              el.classList.remove("opacity-0");
            }, 200 * i);
          });

          // CTA button fades in after all lines
          if (cta) {
            setTimeout(
              () => {
                cta.style.transition = "opacity 0.4s ease, transform 0.4s ease";
                cta.style.opacity = "1";
                cta.style.transform = "translateY(0)";
              },
              200 * lines.length + 150,
            );
          }

          // Footer text last
          if (footer) {
            setTimeout(
              () => {
                footer.style.transition = "opacity 0.4s ease";
                footer.style.opacity = "1";
              },
              200 * lines.length + 400,
            );
          }

          observer.disconnect();
        });
      },
      { threshold: 0.3 },
    );

    const log = document.getElementById("terminal-log");
    if (log) observer.observe(log);
  </script>
</SqueezeLayout>
