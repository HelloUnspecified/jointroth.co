---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Index/Hero.astro";
import ProofStrip from "../components/Index/ProofStrip.astro";
import Diagnostic from "../components/Index/Diagnostic.astro";
import Analysis from "../components/Index/Analysis.astro";
import TheFilter from "../components/Index/TheFilter.astro";
import Override from "../components/Index/Override.astro";
import Evidence from "../components/Index/Evidence.astro";
import Deliverables from "../components/Index/Deliverables.astro";
import Architect from "../components/Index/Architect.astro";
import ProofMarquee from "../components/Index/ProofMarquee.astro";
import CTA from "../components/Index/CTA.astro";

const page = await getEntry("pages", "home");
const { title, description, ogType } = page?.data;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://joinrehuman.com/#website",
      name: "re/Human",
      url: "https://joinrehuman.com",
      description:
        "Human Architecture consulting practice that designs how people find, connect, stay, and build together inside organizations navigating AI transformation.",
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: "https://joinrehuman.com/?s={search_term_string}",
        },
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "Organization",
      "@id": "https://joinrehuman.com/#organization",
      name: "re/Human",
      url: "https://joinrehuman.com",
      logo: {
        "@type": "ImageObject",
        url: "https://joinrehuman.com/favicon.webp",
      },
      founder: {
        "@type": "Person",
        name: "Clark Sell",
      },
      foundingDate: "2024",
      description:
        "Human Architecture consulting practice that designs how people find, connect, stay, and build together inside organizations navigating AI transformation.",
      sameAs: [
        "https://www.linkedin.com/company/joinrehuman",
        "https://x.com/joinrehuman",
        "https://www.youtube.com/@joinrehuman",
      ],
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "customer service",
        url: "https://joinrehuman.com/book",
      },
      areaServed: "US",
      serviceType: "Human Architecture Consulting",
    },
    {
      "@type": "ProfessionalService",
      "@id": "https://joinrehuman.com/#service",
      name: "re/Human",
      provider: {
        "@id": "https://joinrehuman.com/#organization",
      },
      serviceType: "Human Architecture Consulting",
      description:
        "We architect the infrastructure layer underneath culture, community, visibility, and retention for organizations navigating AI transformation.",
      offers: {
        "@type": "Offer",
        name: "Architecture Review",
        description:
          "Private architecture session to map your current ecosystem, identify structural gaps, and deliver a custom blueprint.",
        url: "https://joinrehuman.com/book",
      },
    },
    {
      "@type": "FAQPage",
      "@id": "https://joinrehuman.com/#faq",
      mainEntity: [
        {
          "@type": "Question",
          name: "What is Human Architecture?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Human Architecture is the intentional design of how people find you, connect to each other, stay, and build together. It is the operating system underneath your culture, community, visibility, and retention.",
          },
        },
        {
          "@type": "Question",
          name: "Why does culture break when companies scale?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Culture breaks at scale because it was never intentionally designed. It was inherited, bolted onto tools, and held together by a few key people. Human Architecture designs it into the infrastructure so it works at 20 people and at 2,000.",
          },
        },
        {
          "@type": "Question",
          name: "What is the cost of missing human infrastructure?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "At industry-average turnover of 18%, a 150-person company loses approximately $3.4M per year to replacement costs, plus $2.1M in disengagement productivity loss.",
          },
        },
        {
          "@type": "Question",
          name: "How is re/Human different from a marketing agency?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "re/Human is not a marketing agency, community management firm, or culture consultant. We architect the infrastructure layer — the system underneath culture, community, visibility, and retention that most organizations have never intentionally designed.",
          },
        },
      ],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  ogType={ogType}
  jsonLd={jsonLd}
>

  <Hero />
  <ProofStrip />
  <Diagnostic />
  <Analysis />
  <TheFilter />
  <Override />
  <Evidence />
  <Deliverables />
  <Architect />
  <ProofMarquee />
  <CTA />
</Layout>
