---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import SectionLabel from "../elements/SectionLabel.astro";
import CTAButton from "../elements/CTAButton.astro";

const page = await getEntry("pages", "the-architect");
const { title, description, ogType } = page?.data;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://joinrehuman.com/the-architect#person",
      name: "Clark Sell",
      jobTitle: "Founder & Human Architect",
      worksFor: {
        "@id": "https://joinrehuman.com/#organization",
      },
      description:
        "Community builder, speaker, and systems thinker with 25+ years shipping production code and a decade building community-driven tech events. Founder of re/Human and THAT Conference.",
      sameAs: ["https://www.linkedin.com/in/csell5", "https://x.com/csell5"],
      knowsAbout: [
        "Human Architecture",
        "Community Building",
        "AI Transformation",
        "Software Engineering",
        "Conference Production",
      ],
      alumniOf: [
        {
          "@type": "Organization",
          name: "Allstate",
        },
        {
          "@type": "Organization",
          name: "Microsoft",
        },
        {
          "@type": "Organization",
          name: "Telerik",
        },
      ],
      image: "https://joinrehuman.com/assets/img/people/the-architect.png",
      url: "https://joinrehuman.com/the-architect",
    },
    {
      "@type": "Article",
      "@id": "https://joinrehuman.com/the-architect#article",
      headline: "The Architect | Clark Sell",
      author: {
        "@id": "https://joinrehuman.com/the-architect#person",
      },
      datePublished: "2024-01-01",
      description:
        "Meet Clark Sell - the architect behind re/Human. 25+ years of engineering, a decade of community building, and the founding of THAT Conference — all converging into Human Architecture.",
      publisher: {
        "@id": "https://joinrehuman.com/#organization",
      },
      mainEntityOfPage: "https://joinrehuman.com/the-architect",
    },
  ],
};
---

<Layout title={title} description={description} ogType={ogType} jsonLd={jsonLd}>
  <main class="main-wrapper relative overflow-hidden">
    <!-- ═══════════════════════════════════════════════════════════════
         A. DOSSIER HEADER
    ════════════════════════════════════════════════════════════════ -->
    <section
      class="pt-32 md:pt-44 pb-20 md:pb-32 px-6 bg-rh-warm-light dark:bg-rh-warm-dark"
    >
      <div
        class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-center"
      >
        <!-- Portrait -->
        <div class="lg:col-span-5 relative">
          <div
            class="w-full aspect-4/5 bg-rh-ink rounded-4xl overflow-hidden relative border border-black/10 dark:border-white/10 shadow-2xl"
          >
            <img
              src="/assets/img/people/the-architect.webp"
              alt="Clark Sell - The Architect"
              width="800"
              height="1000"
              fetchpriority="high"
              class="absolute inset-0 w-full h-full object-cover grayscale contrast-125"
            />
            <div
              class="absolute bottom-6 left-6 font-mono text-xs bg-black/80 backdrop-blur-md px-4 py-2 rounded text-rh-chalk border border-white/10 uppercase tracking-widest"
            >
              &gt; ID_VERIFIED // CLEARANCE_GRANTED
            </div>
          </div>
        </div>

        <!-- Dossier Info -->
        <div class="lg:col-span-7 flex flex-col justify-center">
          <SectionLabel
            text="> DOSSIER // THE_ARCHITECT"
            class="text-rh-ember! mb-8"
          />

          <h1
            class="font-heading text-4xl md:text-5xl lg:text-6xl font-black uppercase italic tracking-normal leading-[1.1] text-rh-ink dark:text-rh-chalk mb-10"
          >
            I Built the Code.<br />Then I Built the Culture.
          </h1>

          <!-- Metadata Grid -->
          <div
            class="grid grid-cols-2 md:grid-cols-4 gap-6 border-t border-black/10 dark:border-white/10 pt-8"
          >
            <div>
              <span
                class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 tracking-widest uppercase block mb-1"
                >&gt; YEARS_ACTIVE</span
              >
              <span
                class="text-2xl font-black text-rh-ink dark:text-rh-chalk tracking-tight"
                >25+</span
              >
            </div>
            <div>
              <span
                class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 tracking-widest uppercase block mb-1"
                >&gt; COMMUNITIES</span
              >
              <span
                class="text-2xl font-black text-rh-ink dark:text-rh-chalk tracking-tight"
                >12+</span
              >
            </div>
            <div>
              <span
                class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 tracking-widest uppercase block mb-1"
                >&gt; MEMBERS_REACHED</span
              >
              <span
                class="text-2xl font-black text-rh-ink dark:text-rh-chalk tracking-tight"
                >100K+</span
              >
            </div>
            <div>
              <span
                class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 tracking-widest uppercase block mb-1"
                >&gt; STATUS</span
              >
              <span
                class="text-2xl font-black text-rh-ember tracking-tight flex items-center gap-2"
              >
                <span class="w-2 h-2 rounded-full bg-rh-ember animate-pulse"
                ></span>
                ACTIVE
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         B. THE ORIGIN STORY
    ════════════════════════════════════════════════════════════════ -->
    <section class="py-24 md:py-32 px-6 bg-rh-warm-light dark:bg-rh-warm-dark">
      <div class="max-w-3xl mx-auto" id="origin-section">
        <SectionLabel
          text="> SYS.ORIGIN // THE_BACKSTORY"
          class="text-rh-ember! mb-8"
        />

        <p
          class="text-lg md:text-xl text-rh-ink/70 dark:text-rh-chalk/70 leading-relaxed mb-6"
        >
          I started writing code in the late '90s, back when shipping software
          meant burning CDs and praying the installer worked. Over 25 years,
          I've architected systems for enterprises, scaled platforms under
          extreme load, and shipped production code across every layer of the
          stack.
        </p>
        <p
          class="text-lg md:text-xl text-rh-ink/70 dark:text-rh-chalk/70 leading-relaxed mb-6"
        >
          But somewhere along the way, I noticed a pattern: the most resilient
          companies weren't the ones with the best technology. They were the
          ones with the most devoted communities. The ones whose customers
          evangelized for free, who retained without discounts, who weathered
          platform changes because their people were loyal to each other, not an
          algorithm.
        </p>
        <p
          class="text-lg md:text-xl text-rh-ink/70 dark:text-rh-chalk/70 leading-relaxed"
        >
          So I ran the experiment myself. I founded THAT Conference, grew it
          into one of the largest community-driven tech events in the United
          States, and spent a decade studying how thousands of humans connect,
          build trust, and create belonging in real life. Then I took everything
          I learned from engineering and from community, and built re/Human to
          bring that architecture to the businesses that need it most.
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         C. DUAL-TRACK TIMELINE
    ════════════════════════════════════════════════════════════════ -->
    <section
      class="py-24 md:py-32 px-6 bg-rh-warm-light dark:bg-rh-warm-dark"
      id="timeline-section"
    >
      <div class="max-w-5xl mx-auto">
        <SectionLabel
          text="> SYS.TIMELINE // DUAL_TRACK_RECORD"
          centered
          class="text-rh-ember! mb-4"
        />
        <h2
          class="font-heading text-3xl md:text-5xl font-black uppercase italic tracking-normal leading-[1.1] text-center text-rh-ink dark:text-rh-chalk mb-6"
        >
          Two Careers.<br />One Mission.
        </h2>
        <div
          class="flex items-center justify-center gap-6 mb-20 font-mono text-xs uppercase tracking-widest"
        >
          <span class="flex items-center gap-2 text-rh-ember">
            <span class="w-3 h-px bg-rh-ember"></span> Engineering
          </span>
          <span
            class="flex items-center gap-2 text-emerald-600 dark:text-emerald-400"
          >
            <span class="w-3 h-px bg-emerald-600 dark:bg-emerald-400"></span> Community
          </span>
        </div>

        <!-- Timeline -->
        <div class="relative">
          <!-- Center Line (desktop only) -->
          <div
            class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-black/10 dark:bg-white/10 -translate-x-1/2"
          >
          </div>

          <!-- 1998 - Engineering: Allstate -->
          <div
            class="timeline-entry md:flex md:items-start mb-12 md:mb-16 relative"
          >
            <div class="md:w-1/2 md:pr-12 md:text-right">
              <div
                class="border-l-2 border-rh-ember md:border-l-0 md:border-r-2 pl-6 md:pl-0 md:pr-6 py-2"
              >
                <span
                  class="font-mono text-xs text-rh-ember tracking-widest uppercase block mb-2"
                  >1998 – 2006</span
                >
                <h3
                  class="text-xl font-black uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-2"
                >
                  Allstate | Enterprise Engineering
                </h3>
                <p
                  class="text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
                >
                  Eight years building and shipping enterprise software for one
                  of the largest insurance companies in America. Learned that
                  the hardest bugs are never in the code. They're in the
                  communication between humans.
                </p>
                <span
                  class="font-mono text-[10px] text-rh-ink/30 dark:text-white/30 tracking-widest mt-2 block"
                  >[ ALLSTATE ]</span
                >
              </div>
            </div>
            <div
              class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-3 w-4 h-4 rounded-full bg-rh-ember border-4 border-rh-warm-light dark:border-rh-warm-dark"
            >
            </div>
            <div class="md:w-1/2"></div>
          </div>

          <!-- 2006 - Engineering: Microsoft -->
          <div
            class="timeline-entry md:flex md:items-start mb-12 md:mb-16 relative"
          >
            <div class="md:w-1/2 md:pr-12 md:text-right">
              <div
                class="border-l-2 border-rh-ember md:border-l-0 md:border-r-2 pl-6 md:pl-0 md:pr-6 py-2"
              >
                <span
                  class="font-mono text-xs text-rh-ember tracking-widest uppercase block mb-2"
                  >2006 – 2014</span
                >
                <h3
                  class="text-xl font-black uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-2"
                >
                  Microsoft | Platform & Developer Ecosystem
                </h3>
                <p
                  class="text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
                >
                  Eight years deep in the developer ecosystem at one of the
                  world's largest technology companies. Building platforms,
                  mentoring developers, and learning firsthand that great
                  systems require great culture to sustain them.
                </p>
                <span
                  class="font-mono text-[10px] text-rh-ink/30 dark:text-white/30 tracking-widest mt-2 block"
                  >[ MICROSOFT ]</span
                >
              </div>
            </div>
            <div
              class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-3 w-5 h-5 rounded-full bg-rh-ember border-4 border-rh-warm-light dark:border-rh-warm-dark ring-4 ring-rh-ember/20"
            >
            </div>
            <div class="md:w-1/2"></div>
          </div>

          <!-- 2010 - Community: THAT Conference Founded (while at Microsoft) -->
          <div
            class="timeline-entry md:flex md:items-start mb-12 md:mb-16 relative"
          >
            <div class="md:w-1/2"></div>
            <div
              class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-3 w-5 h-5 rounded-full bg-emerald-500 border-4 border-rh-warm-light dark:border-rh-warm-dark ring-4 ring-emerald-500/20"
            >
            </div>
            <div class="md:w-1/2 md:pl-12">
              <div class="border-l-2 border-emerald-500 pl-6 py-2">
                <span
                  class="font-mono text-xs text-emerald-600 dark:text-emerald-400 tracking-widest uppercase block mb-2"
                  >2010</span
                >
                <h3
                  class="text-xl font-black uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-2"
                >
                  THAT Conference Founded
                </h3>
                <p
                  class="text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
                >
                  While still at Microsoft, launched a community-driven tech
                  conference from zero. Families, campfires, and code. The first
                  real experiment in proving that belonging scales.
                </p>
                <span
                  class="font-mono text-[10px] text-rh-ink/30 dark:text-white/30 tracking-widest mt-2 block"
                  >[ THAT_CONFERENCE ]</span
                >
              </div>
            </div>
          </div>

          <!-- 2014 - Engineering: Telerik -->
          <div
            class="timeline-entry md:flex md:items-start mb-12 md:mb-16 relative"
          >
            <div class="md:w-1/2 md:pr-12 md:text-right">
              <div
                class="border-l-2 border-rh-ember md:border-l-0 md:border-r-2 pl-6 md:pl-0 md:pr-6 py-2"
              >
                <span
                  class="font-mono text-xs text-rh-ember tracking-widest uppercase block mb-2"
                  >2014 – 2016</span
                >
                <h3
                  class="text-xl font-black uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-2"
                >
                  Telerik | Developer Tooling
                </h3>
                <p
                  class="text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
                >
                  Building developer tools and platforms at Telerik. Deepening
                  the understanding that the best products are built by teams
                  who feel like communities, not just headcount.
                </p>
                <span
                  class="font-mono text-[10px] text-rh-ink/30 dark:text-white/30 tracking-widest mt-2 block"
                  >[ TELERIK ]</span
                >
              </div>
            </div>
            <div
              class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-3 w-4 h-4 rounded-full bg-rh-ember border-4 border-rh-warm-light dark:border-rh-warm-dark"
            >
            </div>
            <div class="md:w-1/2"></div>
          </div>

          <!-- 2016 - Both: Unspecified Founded -->
          <div
            class="timeline-entry md:flex md:items-start mb-12 md:mb-16 relative"
          >
            <div class="md:w-1/2 md:pr-12 md:text-right">
              <div
                class="border-l-2 border-rh-ember md:border-l-0 md:border-r-2 pl-6 md:pl-0 md:pr-6 py-2"
              >
                <span
                  class="font-mono text-xs text-rh-ember tracking-widest uppercase block mb-2"
                  >2016</span
                >
                <h3
                  class="text-xl font-black uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-2"
                >
                  Unspecified Founded | The Consulting Era
                </h3>
                <p
                  class="text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
                >
                  Went independent. Founded Unspecified Software Co. and began
                  consulting for a wide range of companies, applying both
                  engineering expertise and community architecture to brands
                  that needed both.
                </p>
                <span
                  class="font-mono text-[10px] text-rh-ink/30 dark:text-white/30 tracking-widest mt-2 block"
                  >[ UNSPECIFIED ]</span
                >
              </div>
            </div>
            <div
              class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-3 w-5 h-5 rounded-full bg-rh-ember border-4 border-rh-warm-light dark:border-rh-warm-dark ring-4 ring-rh-ember/20"
            >
            </div>
            <div class="md:w-1/2"></div>
          </div>

          <!-- 2019 - Community: THAT Conference Peaks -->
          <div
            class="timeline-entry md:flex md:items-start mb-12 md:mb-16 relative"
          >
            <div class="md:w-1/2"></div>
            <div
              class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-3 w-5 h-5 rounded-full bg-emerald-500 border-4 border-rh-warm-light dark:border-rh-warm-dark ring-4 ring-emerald-500/20"
            >
            </div>
            <div class="md:w-1/2 md:pl-12">
              <div class="border-l-2 border-emerald-500 pl-6 py-2">
                <span
                  class="font-mono text-xs text-emerald-600 dark:text-emerald-400 tracking-widest uppercase block mb-2"
                  >2019</span
                >
                <h3
                  class="text-xl font-black uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-2"
                >
                  THAT Conference Peaks
                </h3>
                <p
                  class="text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
                >
                  One of the largest community-driven tech events in the United
                  States. Thousands of attendees across multiple states. Proof
                  that culture, not content, creates loyalty.
                </p>
                <span
                  class="font-mono text-[10px] text-rh-ink/30 dark:text-white/30 tracking-widest mt-2 block"
                  >[ THAT_CONFERENCE ]</span
                >
              </div>
            </div>
          </div>

          <!-- 2020 - Engineering: Digital Pivot -->
          <div
            class="timeline-entry md:flex md:items-start mb-12 md:mb-16 relative"
          >
            <div class="md:w-1/2 md:pr-12 md:text-right">
              <div
                class="border-l-2 border-rh-ember md:border-l-0 md:border-r-2 pl-6 md:pl-0 md:pr-6 py-2"
              >
                <span
                  class="font-mono text-xs text-rh-ember tracking-widest uppercase block mb-2"
                  >2020</span
                >
                <h3
                  class="text-xl font-black uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-2"
                >
                  Digital Infrastructure Pivot
                </h3>
                <p
                  class="text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
                >
                  Pandemic forced every community online overnight. Engineered
                  the digital infrastructure to maintain human connection
                  without physical proximity, and discovered it could scale even
                  further.
                </p>
                <span
                  class="font-mono text-[10px] text-rh-ink/30 dark:text-white/30 tracking-widest mt-2 block"
                  >[ UNSPECIFIED ]</span
                >
              </div>
            </div>
            <div
              class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-3 w-4 h-4 rounded-full bg-rh-ember border-4 border-rh-warm-light dark:border-rh-warm-dark"
            >
            </div>
            <div class="md:w-1/2"></div>
          </div>

          <!-- 2024 - CONVERGENCE: re/Human -->
          <div class="timeline-entry md:flex md:items-start relative">
            <div class="md:w-1/2 md:pr-12 md:text-right hidden md:block">
              <div class="py-2 pr-6">
                <span
                  class="font-mono text-xs text-rh-ink/40 dark:text-white/40 tracking-widest uppercase block"
                  >ENGINEERING</span
                >
                <span class="text-sm text-rh-ink/50 dark:text-rh-chalk/50"
                  >&rarr;</span
                >
              </div>
            </div>
            <div
              class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-3 w-6 h-6 rounded-full border-4 border-rh-warm-light dark:border-rh-warm-dark ring-4 ring-rh-ember/30"
              style="background: linear-gradient(135deg, #FF5733 50%, #10b981 50%);"
            >
            </div>
            <div class="md:w-1/2 md:pl-12">
              <div class="border-l-2 border-rh-ember pl-6 py-2 md:border-l-0">
                <div
                  class="md:border-l-2 md:pl-6"
                  style="border-image: linear-gradient(to bottom, #FF5733, #10b981) 1;"
                >
                  <span
                    class="font-mono text-xs text-rh-ember tracking-widest uppercase block mb-2"
                    >2024</span
                  >
                  <h3
                    class="text-2xl font-black uppercase tracking-tight text-rh-ink dark:text-rh-chalk mb-2"
                  >
                    re/Human Founded
                  </h3>
                  <p
                    class="text-base text-rh-ink/60 dark:text-rh-chalk/60 leading-relaxed"
                  >
                    Allstate. Microsoft. Telerik. A decade of THAT Conference.
                    Years of consulting. All of it fused into one practice under
                    Unspecified: architecting human infrastructure for brands
                    that refuse to be commoditized by AI.
                  </p>
                  <span
                    class="font-mono text-[10px] text-rh-ember tracking-widest mt-2 block"
                    >[ CONVERGENCE ]</span
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         D. CREDENTIALS GRID
    ════════════════════════════════════════════════════════════════ -->
    <section
      class="py-24 md:py-32 px-6 bg-rh-warm-light dark:bg-rh-warm-dark"
      id="credentials-section"
    >
      <div class="max-w-5xl mx-auto">
        <SectionLabel
          text="> SYS.OUTPUT // VERIFIED_CREDENTIALS"
          centered
          class="text-rh-ember! mb-12"
        />

        <div
          class="grid grid-cols-2 lg:grid-cols-4 border border-black/10 dark:border-white/10 divide-x divide-y divide-black/10 dark:divide-white/10 bg-rh-chalk dark:bg-rh-warm-dark rounded-xl overflow-hidden"
        >
          <div class="p-6 lg:p-8 flex flex-col">
            <span
              class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 mb-3 tracking-widest uppercase"
              >&gt; YEARS_SHIPPING</span
            >
            <span
              class="text-3xl font-black text-rh-ink dark:text-white tracking-tight"
              >25+</span
            >
            <span class="text-sm text-rh-ink/50 dark:text-white/50 mt-1"
              >Production code</span
            >
          </div>
          <div class="p-6 lg:p-8 flex flex-col">
            <span
              class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 mb-3 tracking-widest uppercase"
              >&gt; CONFERENCES_RUN</span
            >
            <span
              class="text-3xl font-black text-rh-ink dark:text-white tracking-tight"
              >20+</span
            >
            <span class="text-sm text-rh-ink/50 dark:text-white/50 mt-1"
              >Events produced</span
            >
          </div>
          <div class="p-6 lg:p-8 flex flex-col">
            <span
              class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 mb-3 tracking-widest uppercase"
              >&gt; KEYNOTES</span
            >
            <span
              class="text-3xl font-black text-rh-ink dark:text-white tracking-tight"
              >100+</span
            >
            <span class="text-sm text-rh-ink/50 dark:text-white/50 mt-1"
              >Stages worldwide</span
            >
          </div>
          <div class="p-6 lg:p-8 flex flex-col">
            <span
              class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 mb-3 tracking-widest uppercase"
              >&gt; HUMANS_CONNECTED</span
            >
            <span
              class="text-3xl font-black text-rh-ink dark:text-white tracking-tight"
              >100K+</span
            >
            <span class="text-sm text-rh-ink/50 dark:text-white/50 mt-1"
              >Community members</span
            >
          </div>
          <div class="p-6 lg:p-8 flex flex-col">
            <span
              class="font-mono text-[10px] text-rh-ink/40 dark:text-white/40 mb-3 tracking-widest uppercase"
              >&gt; PLATFORMS_BUILT</span
            >
            <span
              class="text-3xl font-black text-rh-ink dark:text-white tracking-tight"
              >50+</span
            >
