---
export interface Props {
  as?: "h1" | "h2" | "h3";
  size?: "xl" | "lg" | "md" | "sm";
  centered?: boolean;
  class?: string;
}

const {
  as: Tag = "h2",
  size = "lg",
  centered = false,
  class: className = "",
} = Astro.props;

const sizeClasses: Record<string, string> = {
  xl: "text-4xl md:text-7xl lg:text-8xl xl:text-[120px]",
  lg: "text-4xl md:text-6xl lg:text-7xl",
  md: "text-2xl md:text-5xl lg:text-6xl",
  sm: "text-3xl md:text-5xl",
};
---

<Tag
  class:list={[
    "font-heading font-black uppercase italic tracking-normal leading-[1.1] text-rh-ink dark:text-rh-chalk",
    sizeClasses[size],
    centered && "text-center",
    className,
  ]}
>
  <slot />
</Tag>
