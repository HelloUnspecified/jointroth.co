---
import "../css/tailwind.css";
import PostHog from "../components/functional/posthog.astro";
import SEO from "../components/functional/SEO.astro";
import Navbar from "../components/Index/Navbar.astro";
import Footer from "../components/Index/Footer.astro";
import NewsletterModal from "../components/functional/NewsletterModal.astro";
import OverlayMenu from "../components/functional/OverlayMenu.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogImage, ogType, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <link rel="icon" href="/favicon.webp" />

    <!-- Resource hints for third-party origins -->
    <link rel="preconnect" href="https://us.i.posthog.com" />
    <link rel="preconnect" href="https://us-assets.i.posthog.com" crossorigin />
    <link rel="dns-prefetch" href="https://cal.joinrehuman.com" />
    <link rel="dns-prefetch" href="https://blog.joinrehuman.com" />

    <!-- FOUC Prevention: Apply theme before paint -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("rh-theme");
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body
    class="bg-rh-warm-light text-rh-ink dark:bg-rh-warm-dark dark:text-rh-chalk font-body antialiased transition-colors duration-300"
  >
    <!-- Noise Overlay (reduced octaves for GPU perf) -->
    <svg
      class="pointer-events-none fixed inset-0 z-9999 h-full w-full opacity-[0.03]"
      aria-hidden="true"
    >
      <filter id="noiseFilter">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.85"
          numOctaves="2"
          stitchTiles="stitch"></feTurbulence>
      </filter>
      <rect width="100%" height="100%" filter="url(#noiseFilter)"></rect>
    </svg>

    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <NewsletterModal />
    <OverlayMenu />

    <!-- Analytics: loaded after content for better LCP -->
    <PostHog />
  </body>
</html>
