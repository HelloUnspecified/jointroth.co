---
import "../css/tailwind.css";
import SEO from "../components/functional/SEO.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogImage, ogType, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.webp" sizes="any" />

    <!-- Pre-paint setup (no flash): saved Lamplight preference + phone detection.
         `troth-phone` hides the simulated iOS status bar (see the islands' CSS)
         so a real phone doesn't show two status bars. userAgentData.mobile is the
         precise signal but is Chromium-only (undefined in Safari/Firefox), so we
         fall back to a UA check — which is what catches iPhones. -->
    <script is:inline>
      (function () {
        var el = document.documentElement;
        try {
          if (localStorage.getItem("troth-theme") === "dark") {
            el.classList.add("troth-dark");
            el.setAttribute("data-theme", "dark");
          }
        } catch (e) {}
        try {
          var uad = navigator.userAgentData;
          var isPhone =
            uad && typeof uad.mobile === "boolean"
              ? uad.mobile
              : /iPhone|iPod|Android.+Mobile|Windows Phone|BlackBerry|Opera Mini|IEMobile/i.test(
                  navigator.userAgent || "",
                );
          if (isPhone) el.classList.add("troth-phone");
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="font-sans antialiased">
    <slot />
    <style is:global>
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--color-canvas);
        color: var(--color-text);
        -webkit-font-smoothing: antialiased;
        transition: background var(--dur-considered) var(--ease-troth);
      }
    </style>
  </body>
</html>
